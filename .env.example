# Agents Morf — production configuration
APP_NAME=Agents Morf
ENVIRONMENT=development
DEBUG=false
PUBLIC_URL=http://localhost
SECRET_KEY=CHANGE_WITH_OPENSSL_RAND_HEX_32
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:5173,http://localhost

POSTGRES_DB=agents_morf
POSTGRES_USER=agents_morf
POSTGRES_PASSWORD=CHANGE_WITH_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://agents_morf:CHANGE_WITH_A_LONG_RANDOM_PASSWORD@postgres:5432/agents_morf
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agents_morf_context
AUTO_CREATE_SCHEMA=true

# Default chat provider. Production Studio uses Groq; Ollama is restricted (no chat fallback).
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.1-8b-instant
ALLOW_PUBLIC_REGISTRATION=true
REGISTRATION_DEFAULT_PLAN=trial
# Staging helper: include reset/invite tokens in API responses (no SMTP yet).
RETURN_AUTH_TOKENS_IN_RESPONSE=true
PASSWORD_RESET_EXPIRE_MINUTES=60
INVITE_EXPIRE_HOURS=72
ALLOW_LOCAL_CHAT_FALLBACK=false
LOCAL_CPU_THRESHOLD_PERCENT=60
LOCAL_INFERENCE_TIMEOUT_SECONDS=25
LOCAL_MAX_PARALLEL_INFERENCES=1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional cloud providers. Configure only those you use.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Semantic memory and RAG embeddings.
# Set to disabled to use lexical fallback only.
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://ollama:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=

# Optional adapter for an independently installed Grok Build binary.
# The Grok Build source is not modified by Agents Morf.
GROK_BUILD_ENABLED=false
GROK_BUILD_BINARY=grok
GROK_BUILD_CWD=/workspace
GROK_BUILD_MODEL=grok-build
GROK_BUILD_TIMEOUT_SECONDS=300

MEMORY_AUTO_EXTRACT=true
MEMORY_MAX_CONTEXT_CHARS=6000
KNOWLEDGE_MAX_CONTEXT_CHARS=10000
KNOWLEDGE_MAX_FILE_BYTES=10485760
TRAINING_MAX_EXAMPLES=6
TOOL_MAX_ROUNDS=3
TOOL_DEFAULT_TIMEOUT_SECONDS=30
TOOL_ALLOWED_HOSTS=
TOOL_ALLOW_HTTP=false
TOOL_ALLOW_PRIVATE_NETWORKS=false

VITE_API_BASE_URL=/api/v1

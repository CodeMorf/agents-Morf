# Core
APP_NAME=Agents Morf
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
PUBLIC_URL=http://localhost
SECRET_KEY=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost,http://localhost:5173

# Database / cache
POSTGRES_DB=agents_morf
POSTGRES_USER=agents_morf
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://agents_morf:CHANGE_ME@postgres:5432/agents_morf
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# Initial behavior
AUTO_CREATE_SCHEMA=true
DEFAULT_ORGANIZATION_NAME=CodeMorf
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5:7b

# Provider credentials. Keep blank when unused.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# Email (rotate any key that has been shared publicly)
MAIL_ENABLED=false
SMTP2GO_API_URL=https://api.smtp2go.com/v3
SMTP2GO_API_KEY=
MAIL_FROM_ADDRESS=it@codemorf.tech
MAIL_FROM_NAME=Agents Morf
MAIL_REPLY_TO=it@codemorf.tech

# Frontend build-time setting
VITE_API_BASE_URL=/api/v1
